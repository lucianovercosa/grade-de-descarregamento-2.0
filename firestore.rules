rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'lucianovercosa@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isOperational() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'empilhador' || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'mro'
      );
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin() || request.auth.token.email == 'lucianovercosa@gmail.com');
    }

    match /products/{productId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /progress_events/{eventId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /vehicles/{vehicleId} {
      allow read: if true; // Allowed for public links. In a real app, use a subcollection or backend proxy.
      allow create: if isAdmin() || isOperational();
      allow update: if isAdmin() || isOperational();
      allow delete: if isAdmin() || isOperational();
    }

    match /responsibles/{responsibleId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isOperational();
    }
  }
}
